# App
APP_NAME="Albassam Schools App"
APP_URL="https://app.albassam-app.com"

# Session (REQUIRED - Generate a secure random string 32+ chars)
SESSION_PASSWORD="CHANGE_ME_TO_32+_CHARS_RANDOM_SECRET"

# Database (REQUIRED - PostgreSQL connection string)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@your-host.supabase.com:5432/postgres"

# Seed (Optional - Default password for seeded users)
SEED_DEFAULT_PASSWORD="CHANGE_ME"

# DeepSeek AI API (Optional - For AI features)
DEEPSEEK_API_KEY="sk-YOUR_API_KEY_HERE"

# Redis Cache (Optional - For performance optimization)
# Sign up at: https://upstash.com (Free tier: 10K commands/day)
# NOTE: Use the REST URL + REST TOKEN from Upstash console (NOT the Redis password).
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_REST_TOKEN_HERE"

# Cloudflare Tunnel (Recommended - keep token OUT of ecosystem.config.js)
CLOUDFLARED_TOKEN="CHANGE_ME"

# Telegram Alerts (Optional - used by lib/alerting.ts)
TELEGRAM_BOT_TOKEN="CHANGE_ME"
TELEGRAM_ALERT_CHAT_ID="CHANGE_ME"

# Optional webhook for alerts
ALERT_WEBHOOK_URL=""
