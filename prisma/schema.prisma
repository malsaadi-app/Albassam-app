  updatedBy           String? // Who last updated settings

  reviewer User? @relation("HRReviewer", fields: [reviewerUserId], references: [id])
  approver User? @relation("HRApprover", fields: [approverUserId], references: [id])
  updater  User? @relation("HRSettingsUpdater", fields: [updatedBy], references: [id])

  @@index([reviewerUserId])
  @@index([approverUserId])
