  updatedBy           String?

  reviewer User?            @relation("HRTypeReviewer", fields: [reviewerUserId], references: [id])
  approver User?            @relation("HRTypeApprover", fields: [approverUserId], references: [id])
  updater  User?            @relation("HRTypeWorkflowUpdater", fields: [updatedBy], references: [id])
  steps    HRWorkflowStep[]

  @@index([requestType])
  @@index([reviewerUserId])
  @@index([approverUserId])
}

// NOTE: Workflow Builder tables are stored as TEXT columns in the DB (see migrations).
// We model them as String here to avoid relying on PostgreSQL enum types.

model WorkflowDefinition {
  id          String   @id @default(cuid())
  module      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?
  updatedBy   String?

  versions WorkflowVersion[]

  creator User? @relation("WorkflowDefCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updater User? @relation("WorkflowDefUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@index([module])
}

model WorkflowVersion {
  id          String   @id @default(cuid())
  workflowId  String
  version     Int
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now())
  publishedAt DateTime?
  createdBy   String?

  workflow WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  rules    WorkflowRule[]
  steps    WorkflowStepDefinition[]
  runtimeApprovals WorkflowRuntimeApproval[]

  creator User? @relation("WorkflowVersionCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([workflowId, version])
  @@index([workflowId])
}

model WorkflowRule {
  id                String   @id @default(cuid())
  workflowVersionId String
  requestType       String?
  branchId          String?
  enabled           Boolean  @default(true)
  conditionsJson    Json     @default("{}")
  createdAt         DateTime @default(now())

  workflowVersion WorkflowVersion @relation(fields: [workflowVersionId], references: [id], onDelete: Cascade)
  branch          Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([requestType])
  @@index([branchId])
}

model WorkflowStepDefinition {
  id                String   @id @default(cuid())
  workflowVersionId String
  order             Int
  titleAr           String
  titleEn           String?
  stepType          String
  configJson        Json     @default("{}")
  requireComment    Boolean  @default(true)
  allowConsult      Boolean  @default(true)
  allowDelegation   Boolean  @default(true)

  workflowVersion WorkflowVersion @relation(fields: [workflowVersionId], references: [id], onDelete: Cascade)
  runtimeApprovals WorkflowRuntimeApproval[]

  @@unique([workflowVersionId, order])
  @@index([workflowVersionId])
}

// ==================== NEW WORKFLOW RUNTIME SYSTEM ====================
// Runtime approval tracking for new workflow system (WorkflowDefinition-based)
model WorkflowRuntimeApproval {
  id               String   @id @default(cuid())
  versionId        String   // Link to WorkflowVersion
  stepDefinitionId String   // Link to WorkflowStepDefinition
  requestType      String   // HR_REQUEST, PURCHASE_REQUEST, MAINTENANCE_REQUEST, ATTENDANCE_CORRECTION
  requestId        String   // ID of the actual request
  approverId       String   // Current approver
  status           WorkflowRuntimeStatus @default(PENDING)
  level            WorkflowRuntimeLevel? // STAGE, DEPARTMENT, COMPANY (from step config)
  comments         String?
  metadata         Json?    // Additional runtime data
  createdAt        DateTime @default(now())
  reviewedAt       DateTime?
  escalatedAt      DateTime?
  escalatedTo      String?  // User ID if escalated
  notifyOnEntry    Boolean  @default(true)
  notifyOnApproval Boolean  @default(true)
  notifyOnReject   Boolean  @default(true)
  
  version        WorkflowVersion        @relation(fields: [versionId], references: [id], onDelete: Cascade)
  stepDefinition WorkflowStepDefinition @relation(fields: [stepDefinitionId], references: [id], onDelete: Cascade)
  approver       User                   @relation("WorkflowRuntimeApprovals", fields: [approverId], references: [id])
  escalatedToUser User?                 @relation("WorkflowRuntimeEscalations", fields: [escalatedTo], references: [id])
  
  @@index([requestType, requestId])
  @@index([approverId, status])
  @@index([status])
  @@index([createdAt])
  @@index([versionId])
}

enum WorkflowRuntimeStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
  DELEGATED
  CONSULTED
}

enum WorkflowRuntimeLevel {
  STAGE      // مستوى المرحلة
  DEPARTMENT // مستوى القسم
  COMPANY    // مستوى الشركة
}

model HRRoutingRule {
  id              String   @id @default(cuid())
  requestType      String   @unique
  enabled          Boolean  @default(true)
  useStageHead     Boolean  @default(true)
  vpUserId         String?
  hrManagerUserId  String?
  allowDelegation  Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  updatedBy        String?

  vp         User? @relation("HRRoutingVP", fields: [vpUserId], references: [id], onDelete: SetNull)
  hrManager  User? @relation("HRRoutingHRManager", fields: [hrManagerUserId], references: [id], onDelete: SetNull)
  updater    User? @relation("HRRoutingUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@index([vpUserId])
  @@index([hrManagerUserId])
}

model HRWorkflowStep {
  id         String   @id @default(cuid())
  workflowId String
  order      Int
  userId     String
  statusName String // "مراجعة أولية", "موافقة المدير", "اعتماد نهائي", etc.
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  workflow HRRequestTypeWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  user     User                  @relation("HRStepUser", fields: [userId], references: [id])

  @@index([workflowId])
  @@index([order])
  @@index([userId])
}

// ==================== ATTENDANCE REQUESTS ====================

model AttendanceRequest {
  id          String                  @id @default(cuid())
  userId      String
  type        AttendanceRequestType
  requestDate DateTime // التاريخ المطلوب تبريره أو الاستئذان فيه
  reason      String
  status      AttendanceRequestStatus @default(PENDING)
  attachment  String? // مرفق (شهادة طبية، إلخ)

  // For CORRECTION type
  attendanceRecordId String? // معرف سجل الحضور المراد تصحيحه
  originalCheckIn    DateTime? // الوقت الأصلي للحضور
  originalCheckOut   DateTime? // الوقت الأصلي للانصراف
  requestedCheckIn   DateTime? // الوقت المطلوب للحضور
  requestedCheckOut  DateTime? // الوقت المطلوب للانصراف
  correctionType     String? // نوع التصحيح: missing_checkout, wrong_time, forgot_checkin

  reviewedBy    String?
  reviewedAt    DateTime?
  reviewComment String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user     User  @relation("AttendanceRequests", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("AttendanceReviewer", fields: [reviewedBy], references: [id])

  @@index([userId])
  @@index([status])
  @@index([requestDate])
  @@index([attendanceRecordId])
}

enum AttendanceRequestType {
  EXCUSE // تبرير غياب أو تأخير
  PERMISSION // استئذان (مغادرة مبكرة أو تأخير متوقع)
  CORRECTION // تصحيح سجل حضور (وقت خاطئ، نسيان تسجيل)
}

enum AttendanceRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ==================== PROCUREMENT PHASE 4-7 ====================

// Purchase Order - أمر الشراء (Phase 4)
model PurchaseOrder {
  id                String              @id @default(cuid())
  orderNumber       String              @unique
  purchaseRequestId String // ربط مع طلب الشراء الأصلي
  supplierId        String
  orderDate         DateTime            @default(now())
  expectedDelivery  DateTime?
  status            PurchaseOrderStatus @default(PENDING)
  items             String // JSON array: [{name, quantity, unit, unitPrice, totalPrice, specifications}]
  totalAmount       Float
  tax               Float               @default(0)
  discount          Float               @default(0)
  finalAmount       Float
  paymentTerms      String? // شروط الدفع
  deliveryTerms     String? // شروط التسليم
  notes             String?
  attachments       String? // JSON array of file paths
  createdById       String
  approvedById      String?
  approvedAt        DateTime?
  cancelledReason   String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  supplier      Supplier       @relation("SupplierOrders", fields: [supplierId], references: [id])
  goodsReceipts GoodsReceipt[]

  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
  @@index([purchaseRequestId])
}

enum PurchaseOrderStatus {
  PENDING // معلق
  APPROVED // معتمد
  SENT // تم الإرسال للمورد
  CONFIRMED // مؤكد من المورد
  IN_DELIVERY // قيد التوصيل
  DELIVERED // تم التسليم
  CANCELLED // ملغي
  COMPLETED // مكتمل
}

// Goods Receipt - استلام البضائع (Phase 5)
model GoodsReceipt {
  id              String             @id @default(cuid())
  receiptNumber   String             @unique
  purchaseOrderId String
  receiptDate     DateTime           @default(now())
  receivedBy      String // اسم مستلم البضاعة
  items           String // JSON array: [{name, orderedQty, receivedQty, unit, condition, notes}]
  status          GoodsReceiptStatus @default(PENDING)
  qualityCheck    Boolean            @default(false)
  qualityNotes    String?
  damageReport    String? // تقرير الأضرار إن وجدت
  attachments     String? // JSON array (صور، مستندات)
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  purchaseOrder  PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id])
  stockMovements StockMovement[]

  @@index([purchaseOrderId])
  @@index([receiptDate])
  @@index([status])
}

enum GoodsReceiptStatus {
  PENDING // معلق
  INSPECTED // تم الفحص
  ACCEPTED // مقبول
  REJECTED // مرفوض
  PARTIAL // استلام جزئي
}

// Stock Item - عنصر المخزون (Phase 6)
model StockItem {
  id              String    @id @default(cuid())
  itemCode        String    @unique
  itemName        String
  category        String
  unit            String
  currentStock    Float     @default(0)
  minStock        Float     @default(0) // حد إعادة الطلب
  maxStock        Float?
  location        String? // موقع التخزين
  lastRestockDate DateTime?
  unitCost        Float     @default(0)
  totalValue      Float     @default(0)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  movements StockMovement[]

  @@index([category])
  @@index([currentStock])
  @@index([itemCode])
}

// Stock Movement - حركة المخزون (Phase 6)
model StockMovement {
  id             String            @id @default(cuid())
  stockItemId    String
  movementType   StockMovementType
  quantity       Float
  unitCost       Float?
  reference      String? // رقم المرجع (أمر شراء، إذن صرف، إلخ)
  goodsReceiptId String?
  notes          String?
  movedBy        String? // اسم المسؤول عن الحركة
  createdAt      DateTime          @default(now())

  stockItem    StockItem     @relation(fields: [stockItemId], references: [id])
  goodsReceipt GoodsReceipt? @relation(fields: [goodsReceiptId], references: [id])

  @@index([stockItemId])
  @@index([movementType])
  @@index([createdAt])
  @@index([goodsReceiptId])
}

model InventorySettings {
  id                String   @id @default("default")
  allowNegativeStock Boolean  @default(true)
  updatedAt         DateTime @updatedAt
  updatedBy         String?

  updater User? @relation(fields: [updatedBy], references: [id], onDelete: SetNull, name: "InventorySettingsUpdater")
}

model PurchaseRequestAuditLog {
  id          String   @id @default(cuid())
  requestId   String
  actorUserId String
  action      String
  message     String?
  diffJson    String?
  createdAt   DateTime @default(now())

  request PurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  actor   User            @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([actorUserId])
  @@index([createdAt])
}

enum StockMovementType {
  IN // وارد
  OUT // صادر
  ADJUSTMENT // تسوية
  RETURN // إرجاع
  DAMAGE // تالف
}

// Payroll (مسير الرواتب)
model PayrollRun {
  id        String           @id @default(cuid())
  year      Int
  month     Int
  status    PayrollRunStatus @default(DRAFT)
  notes     String?
  createdBy String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  lines PayrollLine[]

  deductionAuditLogs DeductionAuditLog[] @relation("PayrollDeductionAudits")

  @@unique([year, month])
  @@index([status])
  @@index([createdAt])
}

enum PayrollRunStatus {
  DRAFT
  LOCKED
}

model PayrollLine {
  id           String @id @default(cuid())
  payrollRunId String
  employeeId   String

  // snapshots (at time of run)
  employeeName String
  nationalId   String
  bankName     String?
  iban         String?

  // amounts (SAR)
  basicSalary        Float
  transportAllowance Float
  housingAllowance   Float
  otherAllowances    Float
  additions          Float @default(0)
  deductions         Float @default(0)
  totalSalary        Float // computed: basic+allowances+additions-deductions

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payrollRun PayrollRun        @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  items      PayrollLineItem[]

  @@unique([payrollRunId, employeeId])
  @@index([employeeId])
  @@index([payrollRunId])
}

enum PayrollLineItemKind {
  ADDITION
  DEDUCTION
}

model PayrollLineItem {
  id            String              @id @default(cuid())
  payrollLineId String
  kind          PayrollLineItemKind
  title         String
  amount        Float
  notes         String?
  createdAt     DateTime            @default(now())

  payrollLine PayrollLine @relation(fields: [payrollLineId], references: [id], onDelete: Cascade)

  @@index([payrollLineId])
  @@index([kind])
}

model PayrollRecurringItem {
  id         String              @id @default(cuid())
  employeeId String
  kind       PayrollLineItemKind
  title      String
  amount     Float
  active     Boolean             @default(true)
  startAt    DateTime?
  endAt      DateTime?
  createdAt  DateTime            @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([active])
}

// Audit log for attendance deduction adjustments
model DeductionAuditLog {
  id               String   @id @default(cuid())
  payrollRunId     String
  employeeId       String
  employeeName     String
  originalAmount   Float // المبلغ الأصلي المحسوب
  adjustedAmount   Float // المبلغ بعد التعديل
  adjustmentReason String? // سبب التعديل
  ignoredDetails   String? // JSON array of ignored date entries
  adjustedBy       String // User who made the adjustment
  adjustedAt       DateTime @default(now())

  payrollRun PayrollRun @relation("PayrollDeductionAudits", fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   Employee   @relation("EmployeeDeductionAudits", fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([payrollRunId])
  @@index([employeeId])
  @@index([adjustedAt])
}

// ==================== MASTER DATA: DEPARTMENTS & JOB TITLES ====================

model Department {
  id          String   @id @default(cuid())
  nameAr      String   @unique // اسم القسم بالعربي
  nameEn      String? // اسم القسم بالإنجليزي (اختياري)
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  headId    String?    @unique // رئيس القسم
  head      Employee?  @relation("DepartmentHead", fields: [headId], references: [id])
  employees Employee[] @relation("EmployeeDepartment")

  @@index([isActive])
  @@index([sortOrder])
}

model JobTitle {
  id              String      @id @default(cuid())
  nameAr          String      @unique // المسمى الوظيفي بالعربي
  nameEn          String? // المسمى الوظيفي بالإنجليزي (اختياري)
  description     String?
  category        String? // تصنيف الوظيفة (إداري، تعليمي، فني، خدمات)
  suggestedRoleId String? // الدور المقترح للوظيفة (يملأ تلقائياً عند إضافة موظف)
  suggestedRole   SystemRole? @relation("JobTitleSuggestedRole", fields: [suggestedRoleId], references: [id])
  isActive        Boolean     @default(true)
  sortOrder       Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  employees Employee[] @relation("EmployeeJobTitle")

  @@index([isActive])
  @@index([category])
  @@index([sortOrder])
}

// ==================== RBAC (Role-Based Access Control) ====================
// نظام إدارة الصلاحيات المتقدم

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique // "employees.view", "hr_requests.approve"
  nameAr      String // "عرض الموظفين", "الموافقة على الطلبات"
  nameEn      String // "View Employees", "Approve Requests"
  module      String // "employees", "hr", "attendance", "procurement"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles RolePermission[]

  @@index([module])
  @@index([name])
}

model SystemRole {
  id          String   @id @default(cuid())
  name        String   @unique // "SUPER_ADMIN", "HR_MANAGER", "BRANCH_MANAGER"
  nameAr      String // "مدير النظام", "مدير الموارد البشرية"
  nameEn      String // "Super Admin", "HR Manager"
  description String?
  isSystem    Boolean  @default(false) // الأدوار الأساسية (لا تُحذف/تُعدّل)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users            User[]
  permissions      RolePermission[]
  suggestedForJobs JobTitle[]       @relation("JobTitleSuggestedRole")
  employees        Employee[]       @relation("EmployeeSystemRole")

  @@index([isActive])
  @@index([sortOrder])
}

model RolePermission {
  roleId       String
  permissionId String
  grantedAt    DateTime @default(now())
  grantedBy    String? // User ID who granted this permission

  role       SystemRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model PermissionAuditLog {
  id             String   @id @default(cuid())
  userId         String // المستخدم الذي قام بالتعديل
  action         String // "GRANT", "REVOKE", "CREATE_ROLE", "DELETE_ROLE"
  roleId         String?
  roleName       String?
  permissionId   String?
  permissionName String?
  details        String? // JSON details
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ==================== FINANCE MODULE ====================

model FinanceRequest {
  id            String @id @default(cuid())
  requestNumber String @unique

  // Business type
  type String // GOV_FEE, BILL_PAYMENT, REIMBURSEMENT, PETTY_CASH

  // Petty cash fields
  pettyCashInitialAmount Float?
  title                  String
  description            String?
  amount                 Float
  beneficiaryName        String?

  // Attachments JSON: [{name,url}] or file paths
  attachments String?

  // Routing
  department              String? // e.g. HR, PROCUREMENT
  departmentManagerUserId String?
  accountantUserId        String?
  financeManagerUserId    String?

  // Workflow
  currentStep String @default("DEPARTMENT_MANAGER") // DEPARTMENT_MANAGER, ACCOUNTANT_REVIEW, FINANCE_MANAGER_APPROVAL, ACCOUNTANT_EXECUTION, PAID, REJECTED
  status      String @default("PENDING")

  // Comments (hidden from requester; rejection reason visible)
  departmentManagerComment String?
  accountantComment        String?
  financeManagerComment    String?
  rejectionReason          String?

  requesterId String

  reviewedBy String?
  approvedBy String?

  sourceType String? // HR, PROCUREMENT
  sourceId   String? // Link to HRRequest or PurchaseRequest

  createdAt  DateTime  @default(now())
  reviewedAt DateTime?
  approvedAt DateTime?
  paidAt     DateTime?
  updatedAt  DateTime  @updatedAt

  requester User  @relation("FinanceRequester", fields: [requesterId], references: [id])
  reviewer  User? @relation("FinanceReviewer", fields: [reviewedBy], references: [id])
  approver  User? @relation("FinanceApprover", fields: [approvedBy], references: [id])

  departmentManager User? @relation("FinanceDeptManager", fields: [departmentManagerUserId], references: [id])
  accountant        User? @relation("FinanceAccountant", fields: [accountantUserId], references: [id])
  financeManager    User? @relation("FinanceManager", fields: [financeManagerUserId], references: [id])

  pettyCashSettlement PettyCashSettlement?

  @@index([requesterId])
  @@index([status])
  @@index([currentStep])
  @@index([createdAt])
  @@index([sourceType, sourceId])
  @@index([departmentManagerUserId])
  @@index([accountantUserId])
  @@index([financeManagerUserId])
}

enum PettyCashSettlementStatus {
  DRAFT
  SUBMITTED
  ACCOUNTANT_APPROVED
  FINANCE_MANAGER_APPROVED
  REJECTED
  CLOSED
}

enum PettyCashTopUpStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model PettyCashSettlement {
  id               String         @id @default(cuid())
  financeRequestId String         @unique
  financeRequest   FinanceRequest @relation(fields: [financeRequestId], references: [id], onDelete: Cascade)

  status      PettyCashSettlementStatus @default(DRAFT)
  submittedAt DateTime?

  accountantComment     String?
  financeManagerComment String?
  rejectionReason       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items  PettyCashExpenseItem[]
  topUps PettyCashTopUpRequest[]

  @@index([status])
  @@index([createdAt])
}

model PettyCashExpenseItem {
  id           String              @id @default(cuid())
  settlementId String
  settlement   PettyCashSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  date        DateTime?
  vendor      String?
  description String
  amount      Float
  attachments String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([settlementId])
}

model PettyCashTopUpRequest {
  id           String              @id @default(cuid())
  settlementId String
  settlement   PettyCashSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  amount Float
  reason String
  status PettyCashTopUpStatus @default(PENDING)

  requestedById String
  requestedBy   User   @relation("PettyCashTopUpRequestedBy", fields: [requestedById], references: [id])

  approvedById String?
  approvedBy   User?     @relation("PettyCashTopUpApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  rejectionReason String?

  paidAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([settlementId])
  @@index([status])
  @@index([requestedById])
}

// ==================== WORKFLOW SYSTEM ====================

enum WorkflowLevel {
  STAGE // مستوى المرحلة (stage manager/deputy)
  DEPARTMENT // مستوى القسم (department head)
  COMPANY // مستوى الشركة (director, CEO, etc.)
}

enum WorkflowApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
}

model Workflow {
  id              String   @id @default(cuid())
  name            String
  description     String?
  type            String // HR, PROCUREMENT, MAINTENANCE, TASK
  forHRType       String? // Deprecated - use forSpecificType
  forSpecificType String? // Specific request type: LEAVE_REQUEST, PURCHASE_REQUEST_URGENT, etc
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  steps    WorkflowStep[]
  branches WorkflowBranch[]
  stages   WorkflowStage[]

  @@index([type])
  @@index([forSpecificType])
  @@index([isActive])
}

model WorkflowBranch {
  id         String   @id @default(cuid())
  workflowId String
  branchId   String
  createdAt  DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([workflowId, branchId])
  @@index([workflowId])
  @@index([branchId])
}

model WorkflowStage {
  id         String   @id @default(cuid())
  workflowId String
  stageId    String
  createdAt  DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stage    Stage    @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@unique([workflowId, stageId])
  @@index([workflowId])
  @@index([stageId])
}

enum WorkflowApproverType {
  SPECIFIC_USER // موظف محدد
  ROLE // دور معين (مثل: مدير HR)
  DIRECT_MANAGER // المدير المباشر
  SYSTEM_ROLE // دور نظام (مثل: ADMIN)
}

model WorkflowStep {
  id                 String               @id @default(cuid())
  workflowId         String
  name               String // اسم المرحلة (مثل: مراجعة المدير)
  order              Int
  level              WorkflowLevel
  approverType       WorkflowApproverType @default(ROLE)
  approverUserId     String? // إذا كان SPECIFIC_USER
  workflowRoleId     String? // إذا كان ROLE (nullable الآن)
  approverSystemRole String? // إذا كان SYSTEM_ROLE (ADMIN, HR_MANAGER, etc)
  condition          String? // e.g., "amount > 5000"
  allowReject        Boolean              @default(true)
  autoEscalateDays   Int? // تصعيد تلقائي بعد X أيام
  notifyOnEntry      Boolean              @default(true)
  notifyOnApproval   Boolean              @default(true)
  notifyOnReject     Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  workflow     Workflow              @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowRole WorkflowRole?         @relation(fields: [workflowRoleId], references: [id])
  approverUser User?                 @relation("WorkflowStepApprover", fields: [approverUserId], references: [id])
  approvals    WorkflowApprovalLog[]

  @@index([workflowId])
  @@index([order])
  @@index([approverUserId])
  @@index([approverType])
}

model WorkflowRole {
  id          String        @id @default(cuid())
  slug        String        @unique // e.g., "stage_manager", "department_head", "ceo"
  nameAr      String
  nameEn      String
  level       WorkflowLevel
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  steps WorkflowStep[]

  @@index([level])
}

model WorkflowApprovalLog {
  id             String                 @id @default(cuid())
  workflowStepId String
  requestType    String // HR_REQUEST, PURCHASE_REQUEST
  requestId      String
  approverId     String
  status         WorkflowApprovalStatus @default(PENDING)
  comments       String?
  metadata       String? // JSON metadata
  createdAt      DateTime               @default(now())
  reviewedAt     DateTime?

  step      WorkflowStep       @relation(fields: [workflowStepId], references: [id])
  approver  User               @relation("WorkflowApprovals", fields: [approverId], references: [id])
  referrals WorkflowReferral[]

  @@index([requestType, requestId])
  @@index([approverId])
  @@index([status])
  @@index([createdAt])
}

model EmployeeBranchCoverage {
  id         String @id @default(cuid())
  employeeId String
  branchId   String

  module CoverageModule
  // Optional: free-text role within that module (e.g., HR_REP, GATEKEEPER)
  role   String?
  active Boolean        @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([employeeId, branchId, module])
  @@index([branchId, module])
  @@index([employeeId, module])
}

model WorkflowReferral {
  id           String    @id @default(cuid())
  approvalId   String // الموافقة الأصلية
  referredToId String // الشخص المُحال إليه
  referredById String // من قام بالإحالة
  status       String    @default("PENDING") // PENDING, COMPLETED, CANCELLED
  comments     String? // تعليقات الإحالة
  response     String? // رد الشخص المُحال إليه
  priority     String? // URGENT, NORMAL
  createdAt    DateTime  @default(now())
  respondedAt  DateTime?

  approval   WorkflowApprovalLog @relation(fields: [approvalId], references: [id])
  referredTo User                @relation("WorkflowReferredTo", fields: [referredToId], references: [id])
  referredBy User                @relation("WorkflowReferredBy", fields: [referredById], references: [id])

  @@index([approvalId])
  @@index([referredToId])
  @@index([status])
  @@index([createdAt])
}

enum OrgUnitType {
  SCHOOL
  STAGE
  DEPARTMENT
  SUB_DEPARTMENT
}

enum OrgAssignmentType {
  ADMIN      // مشرفين ومديرين
  FUNCTIONAL // أقسام وظيفية
  EXECUTIVE  // إداري تنفيذي
}

enum OrgAssignmentRole {
  HEAD
  SUPERVISOR
  MEMBER
}

enum OrgCoverageScope {
  BRANCH
  MULTI_BRANCH
  ALL
}

model OrgUnit {
  id       String  @id @default(cuid())
  branchId String?
  parentId String?

  name      String
  type      OrgUnitType
  sortOrder Int         @default(0)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch   Branch?   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  parent   OrgUnit?  @relation("OrgUnitParent", fields: [parentId], references: [id], onDelete: Cascade)
  children OrgUnit[] @relation("OrgUnitParent")

  assignments OrgUnitAssignment[]

  @@unique([branchId, parentId, name, type])
  @@index([branchId])
  @@index([parentId])
  @@index([type])
}

model OrgUnitAssignment {
  id         String @id @default(cuid())
  employeeId String
  orgUnitId  String

  assignmentType OrgAssignmentType
  role           OrgAssignmentRole @default(MEMBER)

  // For multi-branch supervisors (e.g., quality, subject supervisors)
  coverageScope     OrgCoverageScope @default(BRANCH)
  coverageBranchIds String? // JSON string array when MULTI_BRANCH

  // For multi-stage teachers: optional weighting
  weightPercent Int?

  isPrimary Boolean @default(false)
  active    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  orgUnit  OrgUnit  @relation(fields: [orgUnitId], references: [id], onDelete: Cascade)

  @@unique([employeeId, orgUnitId, assignmentType])
  @@index([employeeId])
  @@index([orgUnitId])
  @@index([assignmentType])
}


// ==================== TRANSPORT MODULE ====================
model TransportVehicle {
  id          String   @id @default(cuid())
  plateNumber String   @unique

  vehicleType String
  model       String?
  year        Int?
  capacity    Int?
  status      String   @default("ACTIVE")

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId])
  @@index([status])
}
