  @@index([requestId])
  @@index([assetId])
  @@index([action])
  @@index([createdAt])
}

model MaintenanceRequestPart {
  id        String             @id @default(cuid())
  requestId String
  request   MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  partName  String
  quantity  Int
  unitCost  Float
  totalCost Float

  createdAt DateTime @default(now())

  @@index([requestId])
}

// ==================== BRANCH & STAGE MANAGEMENT ====================

model Branch {
  id              String     @id @default(cuid())
  name            String // "مجمع البسام الأهلية بنين"
  type            BranchType // SCHOOL | INSTITUTE | COMPANY
  commercialRegNo String? // رقم السجل التجاري
  buildingNo      String? // رقم المبنى
  address         String? // العنوان الكامل
  city            String? // المدينة
  postalCode      String? // الرمز البريدي

  // GPS & Geofencing
  latitude       Float?
  longitude      Float?
  geofenceRadius Int    @default(100) // meters

  // Contact
  phone String?
  email String?

  // Work Schedule (default for all stages unless overridden)
  workStartTime String @default("07:00")
  workEndTime   String @default("14:00")
  workDays      String @default("0,1,2,3,4") // 0=Sun, 1=Mon, ... 4=Thu, 5=Fri, 6=Sat

  status    BranchStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  stages            Stage[]
  employees         Employee[]
  attendanceRecords AttendanceRecord[]

  coverages EmployeeBranchCoverage[]

  // Maintenance
  maintenanceRequests MaintenanceRequest[]
  assets              Asset[]

  // Workflows
  workflowBranches           WorkflowBranch[]
  maintenanceBranchForwarder MaintenanceBranchForwarder?
  educationalRouting         EducationalRoutingSettings?

  // Org structure (enterprise)
  orgUnits OrgUnit[]

  // Transport
  transportVehicles TransportVehicle[]

  // Workflow builder
  workflowRules WorkflowRule[]

  @@index([name])
  @@index([type])
  @@index([status])
}

model Stage {
  id       String @id @default(cuid())
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  name String // "ابتدائية" | "متوسطة" | "ثانوية" | "رياض أطفال"
  code String? // كود المرحلة (اختياري)

  // GPS (can be different from branch if different building)
  latitude       Float?
  longitude      Float?
  geofenceRadius Int    @default(100) // meters

  // Work Schedule (inherits from branch by default, can override)
  workStartTime String? // if null, use branch default
  workEndTime   String? // if null, use branch default

  // Management
  managerId String? // مدير المرحلة
  manager   Employee? @relation("StageManager", fields: [managerId], references: [id], onDelete: SetNull)

  deputyId String? // نائب مدير المرحلة
  deputy   Employee? @relation("StageDeputy", fields: [deputyId], references: [id], onDelete: SetNull)

  status    StageStatus @default(ACTIVE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  employees         Employee[]
  attendanceRecords AttendanceRecord[]
  workflowStages    WorkflowStage[]

  // Maintenance
  maintenanceRequests MaintenanceRequest[]
  assets              Asset[]

  @@unique([branchId, name])
  @@index([branchId])
  @@index([name])
  @@index([managerId])
  @@index([status])
}

enum BranchType {
  SCHOOL
  INSTITUTE
  COMPANY
}

enum BranchStatus {
  ACTIVE
  INACTIVE
}

enum StageStatus {
  ACTIVE
  INACTIVE
}

