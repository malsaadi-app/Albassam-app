generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                            String                        @id @default(cuid())
  username                      String                        @unique
  displayName                   String
  role                          Role                          @default(USER) // Legacy - keep for backward compatibility
  roleId                        String? // New RBAC system
  systemRole                    SystemRole?                   @relation(fields: [roleId], references: [id])
  passwordHash                  String
  telegramId                    String?
  notificationsEnabled          Boolean                       @default(true)
  notifyOverdue                 Boolean                       @default(true)
  notifyDueSoon                 Boolean                       @default(true)
  notifyDailySummary            Boolean                       @default(true)
  createdAt                     DateTime                      @default(now())
  updatedAt                     DateTime                      @updatedAt
  activityLogs                  ActivityLog[]
  comments                      Comment[]
  employee                      Employee?
  hrRequestsApproved            HRRequest[]                   @relation("ApprovedRequests")
  hrRequestsReviewed            HRRequest[]                   @relation("ReviewedRequests")
  hrRequestsSubmitted           HRRequest[]                   @relation("SubmittedRequests")
  notifications                 Notification[]
  tasksCreated                  Task[]                        @relation("CreatedTasks")
  tasksOwned                    Task[]                        @relation("OwnedTasks")
  taskAssignments               TaskAssignee[]                @relation("TaskAssignees")
  templatesCreated              TaskTemplate[]
  delegationsCreated            HRDelegation[]                @relation("DelegationCreatedBy")
  delegationsReceived           HRDelegation[]                @relation("DelegationDelegateTo")
  hrRequestAuditLogs            HRRequestAuditLog[]
  attendanceRecords             AttendanceRecord[]
  purchaseRequestsCreated       PurchaseRequest[]             @relation("PurchaseRequestsCreated")
  purchaseRequestsReviewed      PurchaseRequest[]             @relation("PurchaseRequestsReviewed")
  purchaseRequestsApproved      PurchaseRequest[]             @relation("PurchaseRequestsApproved")
  hrWorkflowAsReviewer          HRWorkflowSettings[]          @relation("HRReviewer")
  hrWorkflowAsApprover          HRWorkflowSettings[]          @relation("HRApprover")
  hrWorkflowSettingsUpdates     HRWorkflowSettings[]          @relation("HRSettingsUpdater")
  hrTypeWorkflowAsReviewer      HRRequestTypeWorkflow[]       @relation("HRTypeReviewer")
  hrTypeWorkflowAsApprover      HRRequestTypeWorkflow[]       @relation("HRTypeApprover")
  hrTypeWorkflowUpdates         HRRequestTypeWorkflow[]       @relation("HRTypeWorkflowUpdater")
  attendanceRequests            AttendanceRequest[]           @relation("AttendanceRequests")
  attendanceReviews             AttendanceRequest[]           @relation("AttendanceReviewer")
  procurementWorkflowAsReviewer ProcurementCategoryWorkflow[] @relation("ProcurementReviewer")
  procurementWorkflowAsApprover ProcurementCategoryWorkflow[] @relation("ProcurementApprover")
  procurementWorkflowUpdates    ProcurementCategoryWorkflow[] @relation("ProcurementWorkflowUpdater")
  hrWorkflowSteps               HRWorkflowStep[]              @relation("HRStepUser")
  procurementWorkflowSteps      ProcurementWorkflowStep[]     @relation("ProcurementStepUser")
  workflowStepsAsApprover       WorkflowStep[]                @relation("WorkflowStepApprover")
  referralsReceived             WorkflowReferral[]            @relation("WorkflowReferredTo")
  referralsSent                 WorkflowReferral[]            @relation("WorkflowReferredBy")

  // Supplier onboarding requests
  supplierRequestsRequested SupplierRequest[] @relation("SupplierRequestRequestedBy")
  supplierRequestsApproved  SupplierRequest[] @relation("SupplierRequestApprovedBy")
  supplierRequestsRejected  SupplierRequest[] @relation("SupplierRequestRejectedBy")

  // Replacement workflow
  replacementRequestsRequested  ReplacementRequest[]           @relation("ReplacementRequester")
  replacementRequestsEvaluated  ReplacementRequest[]           @relation("ReplacementEvaluator")
  replacementRequestsDecided    ReplacementRequest[]           @relation("ReplacementDecisionMaker")
  replacementNotifications      ReplacementNotification[]      @relation("ReplacementNotifRecipient")
  replacementPerformanceReports ReplacementPerformanceReport[] @relation("ReplacementReportUser")
  replacementTimelineEvents     ReplacementTimeline[]          @relation("ReplacementTimelineUser")

  // Finance Module
  financeRequestsCreated     FinanceRequest[]      @relation("FinanceRequester")
  financeRequestsReviewed    FinanceRequest[]      @relation("FinanceReviewer")
  financeRequestsApproved    FinanceRequest[]      @relation("FinanceApprover")
  financeRequestsDeptManaged FinanceRequest[]      @relation("FinanceDeptManager")
  financeRequestsAccountant  FinanceRequest[]      @relation("FinanceAccountant")
  financeRequestsFinanceMgr  FinanceRequest[]      @relation("FinanceManager")
  workflowApprovals          WorkflowApprovalLog[] @relation("WorkflowApprovals")
  
  // New workflow system runtime approvals
  workflowRuntimeApprovals   WorkflowRuntimeApproval[] @relation("WorkflowRuntimeApprovals")
  workflowRuntimeEscalations WorkflowRuntimeApproval[] @relation("WorkflowRuntimeEscalations")

  // HR routing rules
  hrRoutingVpRules        HRRoutingRule[] @relation("HRRoutingVP")
  hrRoutingHrManagerRules HRRoutingRule[] @relation("HRRoutingHRManager")
  hrRoutingRuleUpdates    HRRoutingRule[] @relation("HRRoutingUpdater")

  workflowDefsCreated WorkflowDefinition[] @relation("WorkflowDefCreatedBy")
  workflowDefsUpdated WorkflowDefinition[] @relation("WorkflowDefUpdatedBy")
  workflowVersionsCreated WorkflowVersion[] @relation("WorkflowVersionCreatedBy")
  inventorySettingsUpdates InventorySettings[] @relation("InventorySettingsUpdater")
  purchaseRequestAuditLogs PurchaseRequestAuditLog[]

  // Maintenance routing
  maintenanceManagerSettings   MaintenanceRoutingSettings[] @relation("MaintenanceManagerUser")
  maintenanceBranchForwardings MaintenanceBranchForwarder[] @relation("MaintenanceBranchForwarderUser")

  // Educational routing
  educationalVpSettings EducationalRoutingSettings[] @relation("VpEducationalUser")

  hrRequestDelegationsTo HRRequestDelegation[] @relation("HRRequestDelegatedTo")
  hrRequestDelegationsBy HRRequestDelegation[] @relation("HRRequestDelegatedBy")

  // Petty cash top-ups
  pettyCashTopUpRequested PettyCashTopUpRequest[] @relation("PettyCashTopUpRequestedBy")
  pettyCashTopUpApproved  PettyCashTopUpRequest[] @relation("PettyCashTopUpApprovedBy")

  @@index([role])
  @@index([roleId])
  @@index([telegramId])
}

model Task {
  id           String          @id @default(cuid())
  title        String
  description  String?
  category     TaskCategory
  status       TaskStatus      @default(NEW)
  priority     TaskPriority    @default(MEDIUM)
  isPrivate    Boolean         @default(false)
  attachments  String?
  dueDate      DateTime?
  checklist    String?
  dependsOn    String?
  ownerId      String
  createdById  String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  activityLogs ActivityLog[]
  comments     Comment[]
  assignees    TaskAssignee[]
  createdBy    User            @relation("CreatedTasks", fields: [createdById], references: [id])
  owner        User            @relation("OwnedTasks", fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([status])
  @@index([category])
  @@index([priority])
  @@index([dueDate])
}

model TaskAssignee {
  id         String   @id @default(cuid())
  taskId     String
  userId     String
  assignedAt DateTime @default(now())
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user       User     @relation("TaskAssignees", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String
  mentions  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([createdAt])
}

model ActivityLog {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  action    String
  changes   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([createdAt])
}

model TaskTemplate {
  id          String       @id @default(cuid())
  name        String
  description String?
  category    TaskCategory
  priority    TaskPriority @default(MEDIUM)
  checklist   String?
  createdById String
  createdAt   DateTime     @default(now())
  createdBy   User         @relation(fields: [createdById], references: [id])
}

model Employee {
  id                 String              @id @default(cuid())
  fullNameAr         String
  fullNameEn         String?
  nationalId         String              @unique
  nationalIdExpiry   DateTime?
  nationality        String
  dateOfBirth        DateTime?
  gender             Gender?
  maritalStatus      MaritalStatus?
  phone              String
  email              String?
  address            String?
  city               String?
  employeeNumber     String              @unique
  department         String // Legacy free-text department name (to be migrated)
  position           String // Legacy free-text position name (to be migrated)
  departmentId       String? // FK to Department master data
  jobTitleId         String? // FK to JobTitle master data
  departmentRef      Department?         @relation("EmployeeDepartment", fields: [departmentId], references: [id])
  jobTitleRef        JobTitle?           @relation("EmployeeJobTitle", fields: [jobTitleId], references: [id])
  directManager      String?
  hireDate           DateTime?
  deductionAuditLogs DeductionAuditLog[] @relation("EmployeeDeductionAudits")
  employmentType     EmploymentType?
  contractEndDate    DateTime?
  status             EmployeeStatus      @default(ACTIVE)
  basicSalary        Float
  housingAllowance   Float               @default(0)
  transportAllowance Float               @default(0)
  otherAllowances    Float               @default(0)
  bankName           String?
  bankAccountNumber  String?
  iban               String?
  education          String?
  specialization     String?
  passportNumber     String?
  passportExpiry     DateTime?
  schoolName         String?
  certifications     String?
  photoUrl           String?
  userId             String?             @unique

  // RBAC System Role Assignment (optional - used when creating User account)
  systemRoleId String?
  systemRole   SystemRole? @relation("EmployeeSystemRole", fields: [systemRoleId], references: [id])

  // Branch & Stage Assignment
  branchId        String?
  branch          Branch?      @relation(fields: [branchId], references: [id])
  stageId         String?
  stage           Stage?       @relation(fields: [stageId], references: [id])
  managedStages   Stage[]      @relation("StageManager")
  deputyForStages Stage[]      @relation("StageDeputy")
  employeeRole    EmployeeRole @default(EMPLOYEE)

  // Cross-branch coverage (e.g., HR covering multiple branches)
  branchCoverages EmployeeBranchCoverage[]

  // Attendance grace overrides (minutes)
  // If set, overrides global AttendanceSettings.lateThresholdMinutes for morning check-in lateness.
  morningGraceMinutes Int?

  // Maintenance
  maintenanceRole               MaintenanceRole?
  maintenanceTeam               MaintenanceTeam?
  maintenanceRequestsCreated    MaintenanceRequest[] @relation("RequestCreator")
  maintenanceRequestsAssigned   MaintenanceRequest[] @relation("AssignedTechnician")
  maintenanceRequestsCompleted  MaintenanceRequest[] @relation("Completer")
  maintenanceRequestsAssignedBy MaintenanceRequest[] @relation("Assigner")
  maintenanceComments           MaintenanceComment[]
  maintenanceHistory            MaintenanceHistory[]

  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  documents             Document[]
  payrollLines          PayrollLine[]
  recurringPayrollItems PayrollRecurringItem[]
  user                  User?                  @relation(fields: [userId], references: [id])
  leaves                Leave[]
  leaveBalance          LeaveBalance?

  // Org structure assignments (enterprise)
  orgAssignments OrgUnitAssignment[]

  // ==================== POSITION & HEADCOUNT MANAGEMENT ====================
  currentPosition OrganizationalPosition? @relation("CurrentPosition")

  // Replacement workflow (as the employee being replaced / new hire)
  replacementsAsCurrent ReplacementRequest[] @relation("ReplacementCurrentEmployee")
  replacementsAsNew     ReplacementRequest[] @relation("ReplacementNewEmployee")

  positionsOpened                  OrganizationalPosition[] @relation("PositionOpenedBy")
  positionHistoryPerformed         PositionHistory[]        @relation("PositionHistoryPerformer")
  positionHistoryAsEmployee        PositionHistory[]        @relation("PositionHistoryEmployee")
  positionOpeningRequestsRequested PositionOpeningRequest[] @relation("PositionOpeningRequestedBy")
  positionOpeningRequestsReviewed  PositionOpeningRequest[] @relation("PositionOpeningReviewer")
  headcountApprovals               DepartmentHeadcount[]    @relation("HeadcountApprovedBy")
  headcountChangeRequestsRequested HeadcountChangeRequest[] @relation("HeadcountRequestedBy")
  headcountChangeRequestsReviewed  HeadcountChangeRequest[] @relation("HeadcountReviewer")
  jobApplicationsCreated           JobApplication[]         @relation("JobApplicationCreatedBy")
  departmentHeaded                 Department?              @relation("DepartmentHead")

  @@index([employeeNumber])
  @@index([nationalId])
  @@index([status])
  @@index([department])
  @@index([branchId])
  @@index([stageId])
}

model Leave {
  id          String      @id @default(cuid())
  employeeId  String
  type        LeaveType
  startDate   DateTime
  endDate     DateTime
  days        Int
  reason      String?
  status      LeaveStatus @default(PENDING)
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNotes String?
  attachments String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
  @@index([type])
  @@index([startDate])
}

model LeaveBalance {
  id                 String   @id @default(cuid())
  employeeId         String   @unique
  annualTotal        Int      @default(30)
  annualUsed         Int      @default(0)
  annualRemaining    Int      @default(30)
  casualTotal        Int      @default(5)
  casualUsed         Int      @default(0)
  casualRemaining    Int      @default(5)
  emergencyTotal     Int      @default(0) // إجازات اضطرارية (5 للإناث، 0 للذكور افتراضياً)
  emergencyUsed      Int      @default(0)
  emergencyRemaining Int      @default(0)
  year               Int
  updatedAt          DateTime @updatedAt
  employee           Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([year])
}

model Document {
  id         String       @id @default(cuid())
  employeeId String
  title      String
  type       DocumentType
  category   String?
  filePath   String
  fileName   String
  fileSize   Int
  mimeType   String
  issueDate  DateTime?
  expiryDate DateTime?
  notes      String?
  uploadedBy String
  uploadedAt DateTime     @default(now())
  employee   Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([type])
  @@index([expiryDate])
}

model HRRequest {
  id                    String                @id @default(cuid())
  type                  RequestType
  status                RequestStatus         @default(PENDING_REVIEW)
  currentWorkflowStep   Int? // Current step order in workflow (null = not started, 0 = step 1, etc.)
  employeeId            String
  startDate             DateTime?
  endDate               DateTime?
  leaveType             String?
  destination           String?
  travelDate            DateTime?
  departureDate         DateTime?
  returnDate            DateTime?
  amount                Float?
  period                String?
  purpose               String?
  recipientOrganization String?
  reason                String?
  attachment            String?
  attachments           String?
  reviewedBy            String?
  reviewComment         String?
  reviewedAt            DateTime?
  approvedBy            String?
  approvalComment       String?
  approvedAt            DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  approver              User?                 @relation("ApprovedRequests", fields: [approvedBy], references: [id])
  reviewer              User?                 @relation("ReviewedRequests", fields: [reviewedBy], references: [id])
  employee              User                  @relation("SubmittedRequests", fields: [employeeId], references: [id])
  auditLogs             HRRequestAuditLog[]
  delegations           HRRequestDelegation[]

  @@index([employeeId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([currentWorkflowStep])
}

model HRRequestAuditLog {
  id          String   @id @default(cuid())
  requestId   String
  actorUserId String
  action      String
  message     String?
  diffJson    String?
  createdAt   DateTime @default(now())

  request HRRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  actor   User      @relation(fields: [actorUserId], references: [id])

  @@index([requestId])
  @@index([actorUserId])
  @@index([createdAt])
}

model HRDelegation {
  id               String    @id @default(cuid())
  delegateToUserId String
  createdByUserId  String
  startAt          DateTime
  endAt            DateTime
  active           Boolean   @default(true)
  startNotifiedAt  DateTime?
  endNotifiedAt    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  delegateTo User @relation("DelegationDelegateTo", fields: [delegateToUserId], references: [id])
  createdBy  User @relation("DelegationCreatedBy", fields: [createdByUserId], references: [id])

  @@index([delegateToUserId])
  @@index([active])
  @@index([startAt])
  @@index([endAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  relatedId String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ==================== REPLACEMENT WORKFLOW ====================

model ReplacementRequest {
  id            Int    @id @default(autoincrement())
  requestNumber String @unique // REP-2026-001

  // Position & Employees
  positionId Int
  position   OrganizationalPosition @relation("ReplacementPosition", fields: [positionId], references: [id])

  currentEmployeeId String
  currentEmployee   Employee @relation("ReplacementCurrentEmployee", fields: [currentEmployeeId], references: [id])

  newEmployeeId String
  newEmployee   Employee @relation("ReplacementNewEmployee", fields: [newEmployeeId], references: [id])

  // Probation Period
  probationStartDate DateTime
  probationEndDate   DateTime
  probationMonths    Int // 1-3

  // Status
  status String @default("ACTIVE") // ACTIVE, EXTENDED, COMPLETED_SUCCESS, COMPLETED_FAILED, CANCELLED

  // Evaluation
  evaluationScore   Int?
  evaluationNotes   String?
  evaluatedByUserId String?
  evaluatedByUser   User?     @relation("ReplacementEvaluator", fields: [evaluatedByUserId], references: [id])
  evaluatedAt       DateTime?

  // Decision
  decision         String? // CONFIRM_NEW, KEEP_OLD, EXTEND_PROBATION
  decisionReason   String?
  decisionByUserId String?
  decisionByUser   User?     @relation("ReplacementDecisionMaker", fields: [decisionByUserId], references: [id])
  decisionAt       DateTime?

  // Justification
  replacementReason   String
  expectedImprovement String?

  // Metadata
  requestedByUserId String
  requestedByUser   User     @relation("ReplacementRequester", fields: [requestedByUserId], references: [id])
  requestedAt       DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  notifications      ReplacementNotification[]
  performanceReports ReplacementPerformanceReport[]
  timeline           ReplacementTimeline[]

  // Back relation for OrganizationalPosition.activeReplacement
  activeForPosition OrganizationalPosition? @relation("PositionActiveReplacement")

  @@index([positionId])
  @@index([status])
  @@index([probationEndDate])
}

model ReplacementNotification {
  id            Int                @id @default(autoincrement())
  replacementId Int
  replacement   ReplacementRequest @relation(fields: [replacementId], references: [id], onDelete: Cascade)

  notificationType String // WEEK_BEFORE_END, DAY_BEFORE_END, EVALUATION_DUE, DECISION_DUE, STARTED, DECISION_MADE
  scheduledFor     DateTime
  sent             Boolean   @default(false)
  sentAt           DateTime?

  recipientUserId String
  recipientUser   User   @relation("ReplacementNotifRecipient", fields: [recipientUserId], references: [id])

  message   String
  createdAt DateTime @default(now())

  @@index([replacementId])
  @@index([recipientUserId])
  @@index([sent])
  @@index([scheduledFor])
}

model ReplacementPerformanceReport {
  id            Int                @id @default(autoincrement())
  replacementId Int
  replacement   ReplacementRequest @relation(fields: [replacementId], references: [id], onDelete: Cascade)

  reportDate   DateTime @default(now())
  reportPeriod String // WEEK_1, WEEK_2, MONTH_1, MONTH_2, FINAL

  // Current Employee Metrics
  currentEmployeeScore Int?
  currentEmployeeNotes String?

  // New Employee Metrics
  newEmployeeScore Int?
  newEmployeeNotes String?

  // Comparison
  comparisonNotes String?
  recommendation  String? // CONTINUE, CONFIRM_NEW, CANCEL

  // Reporter
  reportedByUserId String
  reportedByUser   User   @relation("ReplacementReportUser", fields: [reportedByUserId], references: [id])

  createdAt DateTime @default(now())

  @@index([replacementId])
  @@index([reportDate])
  @@index([reportedByUserId])
}

model ReplacementTimeline {
  id            Int                @id @default(autoincrement())
  replacementId Int
  replacement   ReplacementRequest @relation(fields: [replacementId], references: [id], onDelete: Cascade)

  eventType        String // STARTED, REPORT_SUBMITTED, EVALUATION_ADDED, DECISION_MADE, COMPLETED, CANCELLED, PROBATION_EXTENDED
  eventDescription String

  performedByUserId String?
  performedByUser   User?   @relation("ReplacementTimelineUser", fields: [performedByUserId], references: [id])

  metadataJson String?
  createdAt    DateTime @default(now())

  @@index([replacementId])
  @@index([createdAt])
  @@index([eventType])
}

// ==================== POSITION & HEADCOUNT MANAGEMENT ====================

model OrganizationalPosition {
  id         Int     @id @default(autoincrement())
  code       String  @unique // POS-2026-001
  title      String // معلم رياضيات
  titleEn    String? // Math Teacher
  department String // القسم
  level      String // المستوى الوظيفي (Junior/Mid/Senior/Manager)
  status     String  @default("VACANT") // VACANT, FILLED, CLOSED

  // Current occupant
  currentEmployeeId String?   @unique
  currentEmployee   Employee? @relation("CurrentPosition", fields: [currentEmployeeId], references: [id])

  // Replacement workflow
  inReplacement       Boolean             @default(false)
  activeReplacementId Int?                @unique
  activeReplacement   ReplacementRequest? @relation("PositionActiveReplacement", fields: [activeReplacementId], references: [id])

  // Metadata
  salaryMin    Float?
  salaryMax    Float?
  description  String?
  requirements String?

  // History
  openedAt     DateTime  @default(now())
  openedBy     String
  openedByUser Employee  @relation("PositionOpenedBy", fields: [openedBy], references: [id])
  closedAt     DateTime?
  closedReason String?

  // Approval proof (when opened)
  approvalDocument String? // File path to approval doc
  approvalNotes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  applications              JobApplication[]
  history                   PositionHistory[]
  createdFromOpeningRequest PositionOpeningRequest? @relation("PositionOpeningRequestCreatedPosition")
  replacementRequests       ReplacementRequest[]    @relation("ReplacementPosition")

  @@index([department])
  @@index([status])
  @@index([level])
}

model DepartmentHeadcount {
  id            Int    @id @default(autoincrement())
  department    String @unique // القسم
  approvedCount Int // الكادر المعتمد
  currentCount  Int    @default(0) // العدد الفعلي (calculated)

  // Approval for headcount
  approvalDocument String? // File path
  approvedBy       String?
  approvedByUser   Employee? @relation("HeadcountApprovedBy", fields: [approvedBy], references: [id])
  approvedAt       DateTime?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // History
  changes HeadcountChangeRequest[]

  @@index([department])
}

model HeadcountChangeRequest {
  id            Int    @id @default(autoincrement())
  requestNumber String @unique // HCR-2026-001

  department            String
  departmentHeadcountId Int
  departmentHeadcount   DepartmentHeadcount @relation(fields: [departmentHeadcountId], references: [id])

  requestType    String // INCREASE, DECREASE
  currentCount   Int
  requestedCount Int
  changeAmount   Int // +5, -2

  justification    String
  approvalDocument String // Required PDF/image

  // Requester
  requestedBy     String
  requestedByUser Employee @relation("HeadcountRequestedBy", fields: [requestedBy], references: [id])
  requestedAt     DateTime @default(now())

  // Approval workflow
  status         String    @default("PENDING") // PENDING, APPROVED, REJECTED
  reviewedBy     String?
  reviewedByUser Employee? @relation("HeadcountReviewer", fields: [reviewedBy], references: [id])
  reviewedAt     DateTime?
  reviewNotes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([department])
  @@index([status])
  @@index([requestedAt])
}

model PositionHistory {
  id         Int                    @id @default(autoincrement())
  positionId Int
  position   OrganizationalPosition @relation(fields: [positionId], references: [id])

  action     String // OPENED, FILLED, VACATED, CLOSED
  employeeId String?
  employee   Employee? @relation("PositionHistoryEmployee", fields: [employeeId], references: [id])

  performedBy     String
  performedByUser Employee @relation("PositionHistoryPerformer", fields: [performedBy], references: [id])

  notes     String?
  createdAt DateTime @default(now())

  @@index([positionId])
  @@index([createdAt])
  @@index([action])
}

model PositionOpeningRequest {
  id            Int    @id @default(autoincrement())
  requestNumber String @unique // POR-2026-001

  title            String
  department       String
  level            String
  justification    String
  approvalDocument String // Required

  salaryMin Float?
  salaryMax Float?

  // Requester
  requestedBy     String
  requestedByUser Employee @relation("PositionOpeningRequestedBy", fields: [requestedBy], references: [id])
  requestedAt     DateTime @default(now())

  // Approval workflow
