// ==================== MAINTENANCE MANAGEMENT ====================

model MaintenanceRequest {
  id            String @id @default(cuid())
  requestNumber String @unique // REQ-2026-0001

  type     MaintenanceType
  kind     MaintenanceKind     @default(CORRECTIVE)
  category String
  priority MaintenancePriority @default(NORMAL)
  status   MaintenanceStatus   @default(SUBMITTED)

  // Location
  branchId        String
  branch          Branch  @relation(fields: [branchId], references: [id])
  stageId         String?
  stage           Stage?  @relation(fields: [stageId], references: [id])
  locationDetails String

  // Description
  description String
  imagesJson  String? // JSON array of uploaded image URLs

  // Asset (optional)
  assetId String?
  asset   Asset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)

  // Assignment
  assignedToId String?
  assignedTo   Employee? @relation("AssignedTechnician", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedAt   DateTime?
  assignedById String?
  assignedBy   Employee? @relation("Assigner", fields: [assignedById], references: [id], onDelete: SetNull)

  // Requester
  requestedById String
  requestedBy   Employee @relation("RequestCreator", fields: [requestedById], references: [id])
  requestedAt   DateTime @default(now())

  // Completion
  completedAt   DateTime?
  completedById String?
  completedBy   Employee? @relation("Completer", fields: [completedById], references: [id], onDelete: SetNull)

  // Rating (after completion)
  rating        Int?
  ratingComment String?

  // Costs
  laborHours Float?
  partsCost  Float?
  totalCost  Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments MaintenanceComment[]
  history  MaintenanceHistory[]
  parts    MaintenanceRequestPart[]

  @@index([status])
  @@index([type])
  @@index([priority])
  @@index([branchId])
  @@index([stageId])
  @@index([assignedToId])
  @@index([requestedById])
  @@index([assetId])
  @@index([createdAt])
}

model Asset {
  id          String @id @default(cuid())
  assetNumber String @unique // AST-2026-0001

  type         String
  category     AssetCategory
  name         String
  serialNumber String?

  // Location
  branchId        String
  branch          Branch  @relation(fields: [branchId], references: [id])
  stageId         String?
  stage           Stage?  @relation(fields: [stageId], references: [id])
  locationDetails String

  // Purchase info
  purchaseDate  DateTime?
  warrantyStart DateTime?
  warrantyEnd   DateTime?
  purchasePrice Float?

  status AssetStatus @default(GOOD)

  // Preventive maintenance
  lastMaintenanceDate DateTime?
  nextMaintenanceDate DateTime?
  maintenanceInterval Int? // days

  maintenanceRequests MaintenanceRequest[]
  maintenanceHistory  MaintenanceHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([status])
  @@index([branchId])
  @@index([stageId])
  @@index([serialNumber])
}

model MaintenanceComment {
  id        String             @id @default(cuid())
  requestId String
  request   MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  userId String
  user   Employee @relation(fields: [userId], references: [id])

  comment    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([requestId])
  @@index([createdAt])
}

model MaintenanceHistory {
  id        String              @id @default(cuid())
  requestId String?
  request   MaintenanceRequest? @relation(fields: [requestId], references: [id], onDelete: Cascade)

  assetId String?
  asset   Asset?  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  action   MaintenanceHistoryAction
  oldValue String?
  newValue String?
  notes    String?

  userId String
  user   Employee @relation(fields: [userId], references: [id])

