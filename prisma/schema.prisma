  requestNumber       String                @unique
  requestedById       String
  department          String
  category            PurchaseCategory
  items               String // JSON array of {name, quantity, unit, specifications, estimatedPrice}
  priority            PurchasePriority      @default(NORMAL)
  status              PurchaseRequestStatus @default(PENDING_REVIEW)
  currentWorkflowStep Int? // Current step order in workflow
  justification       String?
  attachments         String? // JSON array of file paths
  estimatedBudget     Float?
  requiredDate        DateTime?
  supplierId          String? // المورد المفضل
  reviewedById        String?
  reviewedAt          DateTime?
  reviewNotes         String?
  approvedById        String?
  approvedAt          DateTime?
  approvalNotes       String?
  rejectedReason      String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  requestedBy User  @relation("PurchaseRequestsCreated", fields: [requestedById], references: [id])
  reviewedBy  User? @relation("PurchaseRequestsReviewed", fields: [reviewedById], references: [id])
  approvedBy  User? @relation("PurchaseRequestsApproved", fields: [approvedById], references: [id])
